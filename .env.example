MENTOR_INDEX_DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mentor_index
MENTOR_INDEX_EMBEDDING_BACKEND=sentence-transformers
MENTOR_INDEX_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
MENTOR_INDEX_EMBEDDING_DIMENSION=512
MENTOR_INDEX_EMBEDDING_DEVICE=auto
MENTOR_INDEX_LLM_BASE_URL=https://api.openai.com/v1
MENTOR_INDEX_LLM_API_KEY=
MENTOR_INDEX_LLM_MODEL=gpt-4o-mini
MENTOR_INDEX_USER_AGENT=mentor-index/0.1 (+https://github.com/example/mentor-index)
MENTOR_INDEX_MAX_CRAWL_DEPTH=2
MENTOR_INDEX_MAX_PAGES_PER_FACULTY=12
MENTOR_INDEX_MAX_EXTERNAL_DOMAINS=8
MENTORDB_API_BASE_URL=http://127.0.0.1:8000
NEXT_PUBLIC_MENTORDB_API_BASE_URL=http://127.0.0.1:8000
